{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "paths": {
      "@unforgit/shared": ["./packages/shared/src/index.ts"],
      "@unforgit/core": ["./packages/core/src/index.ts"],
      "@unforgit/db": ["./packages/db/src/index.ts"],
      "@unforgit/config": ["./packages/config/src/index.ts"],
      "@unforgit/tools": ["./packages/tools/src/index.ts"]
    }
  },
  "include": [
    "packages/*/src/**/*",
    "apps/api/src/**/*",
    "apps/cli/src/**/*",
    "apps/mcp/src/**/*"
  ],
  "exclude": ["node_modules", "dist", "apps/web", "apps/admin", "apps/website"]
}
