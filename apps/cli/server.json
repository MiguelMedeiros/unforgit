      "transport": {
        "type": "stdio"
      }
    }
  ],
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/MiguelMedeiros/unforgit/main/docs/unforgit-icon.png",
      "mimeType": "image/png",
      "sizes": ["400x400"]
    }
  ]
}
