# PostgreSQL connection for remote/team sync (optional for local-only usage)
DATABASE_URL="postgresql://user:password@localhost:5432/unforgit?schema=public"

# API server configuration
PORT=3737
HOST=0.0.0.0

# =============================================================================
# Admin Panel Authentication
# =============================================================================
# Password for the admin panel login (required for /v1/admin/* routes)
# Used to generate JWT tokens for admin session management
ADMIN_PASSWORD=change-me-to-a-secure-password

# =============================================================================
# GitHub OAuth (Optional - enables GitHub login for admin dashboard)
# =============================================================================
# Create a GitHub OAuth App: https://github.com/settings/developers
# Set Authorization callback URL to: http://localhost:3737/v1/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3737/v1/auth/github/callback

# URL where the admin dashboard is running (for OAuth redirects)
ADMIN_DASHBOARD_URL=http://localhost:3939

# JWT Secret for signing user tokens (defaults to ADMIN_PASSWORD if not set)
JWT_SECRET=

# =============================================================================
# Unforgit API Key (for CLI & MCP authentication)
# =============================================================================
# Generated in the admin panel (localhost:3939/keys).
# Used by the MCP server and CLI to authenticate with the remote API.
# The MCP server loads this .env automatically from the repo root.
UNFORGIT_API_KEY=

# =============================================================================
# OpenAI API Key (OPTIONAL for local CLI, RECOMMENDED for server)
# =============================================================================
#
# The MCP server automatically loads this .env file from the repo root.
# No need to put API keys in IDE MCP config files.
#
# Without this key: Unforgit works with full-text search (FTS5)
# With this key: Enables semantic search via AI embeddings + auto-consolidation
# 
# LOCAL CLI & MCP features that require OpenAI:
#   - Semantic search (recall uses hybrid scoring with embeddings)
#   - Embeddings backfill (generate embeddings for existing memories)
#   - Auto-consolidation suggestions with AI
#   - unforgit_embedding_recall MCP tool
#
# Features that work WITHOUT OpenAI:
#   - All core features (add, recall via FTS, promote, sync, etc.)
#   - Manual consolidation
#   - Team sync
#   - Web dashboard
#
OPENAI_API_KEY=sk-your-api-key-here

# =============================================================================
# Server-Side AI Configuration (for team deployments)
# =============================================================================
# When running the Unforgit server for a team, these settings enable
# centralized AI features so individual developers don't need their own keys.

# Auto-embedding: automatically generate embeddings when memories are created
# Set to "true" to enable server-side auto-embedding on every store() call
AUTO_EMBEDDING_ENABLED=false

# LLM model for auto-consolidation (default: gpt-5.4)
# Used by POST /v1/auto-consolidate endpoint
CONSOLIDATION_MODEL=gpt-5.4

# =============================================================================
# Server API Endpoints (when OPENAI_API_KEY is set on server)
# =============================================================================
#
# Semantic Search:
#   POST /v1/recall - Returns hybrid search results (semantic + FTS)
#
# Embeddings:
#   POST /v1/embeddings/generate/:memoryId - Generate embedding for one memory
#   POST /v1/embeddings/backfill - Generate embeddings for all memories
#   GET  /v1/embeddings/stats?orgId=x&repoId=y - Embedding coverage stats
#
# Auto-Consolidation:
#   POST /v1/auto-consolidate/preview - Find consolidation candidates
#   POST /v1/auto-consolidate - Find and execute consolidation with LLM
#   POST /v1/auto-consolidate/execute - Execute specific group consolidation
#
# Suggestions & Health:
#   GET /v1/suggestions?orgId=x&repoId=y - AI-powered curation suggestions
#   GET /v1/health/repo?orgId=x&repoId=y - Repository health report
#
