datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../packages/db/src/generated/prisma"
}

model Memory {
  id           String    @id @default(uuid()) @db.Uuid
  orgId        String    @map("org_id")
  repoId       String    @map("repo_id")
  scopeType    String    @default("repo") @map("scope_type")
  memoryType   String    @map("memory_type")
  visibility   String    @default("repo")
  status       String    @default("active")
  text         String
  summary      String?
  tags         String[]
  sourceRefs   Json?     @map("source_refs")
  confidence   Float?
  ttlSeconds   Int?      @map("ttl_seconds")
  supersedesId String?   @map("supersedes_id") @db.Uuid
  version      Int       @default(1)
  deletedAt    DateTime? @map("deleted_at")
  deletedBy    String?   @map("deleted_by")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  supersedes   Memory?  @relation("Supersedes", fields: [supersedesId], references: [id])
  supersededBy Memory[] @relation("Supersedes")

  sourceLinks  MemoryLink[] @relation("SourceLinks")
  targetLinks  MemoryLink[] @relation("TargetLinks")
  embedding    MemoryEmbedding?
  usages       MemoryUsage[]

  @@index([orgId, repoId, memoryType, status])
  @@index([orgId, repoId, updatedAt])
  @@index([deletedAt])
  @@map("memories")
}

model MemoryEmbedding {
  memoryId  String   @id @map("memory_id") @db.Uuid
  embedding Bytes
  model     String
  createdAt DateTime @default(now()) @map("created_at")

  memory Memory @relation(fields: [memoryId], references: [id], onDelete: Cascade)

  @@map("memory_embeddings")
}

model MemoryUsage {
  id         Int      @id @default(autoincrement())
  memoryId   String   @map("memory_id") @db.Uuid
  recalledAt DateTime @default(now()) @map("recalled_at")
  query      String?
  sessionId  String?  @map("session_id")

  memory Memory @relation(fields: [memoryId], references: [id], onDelete: Cascade)

  @@index([memoryId])
  @@index([recalledAt])
  @@map("memory_usage")
}

model MemoryLink {
  id        String   @id @default(uuid()) @db.Uuid
  sourceId  String   @map("source_id") @db.Uuid
  targetId  String   @map("target_id") @db.Uuid
  linkType  String   @map("link_type")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  source Memory @relation("SourceLinks", fields: [sourceId], references: [id], onDelete: Cascade)
  target Memory @relation("TargetLinks", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId, linkType])
  @@map("memory_links")
}

model Tombstone {
  id        String    @id @default(uuid()) @db.Uuid
  memoryId  String    @map("memory_id") @db.Uuid
  orgId     String    @map("org_id")
  repoId    String    @map("repo_id")
  deletedAt DateTime  @map("deleted_at")
  deletedBy String?   @map("deleted_by")
  syncedAt  DateTime? @map("synced_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@unique([memoryId])
  @@index([orgId, repoId, syncedAt])
  @@map("tombstones")
}

model ApiKey {
  id         String    @id @default(uuid()) @db.Uuid
  key        String    @unique
  name       String
  orgId      String    @map("org_id")
  repoId     String?   @map("repo_id")
  userId     String?   @map("user_id") @db.Uuid
  createdBy  String?   @map("created_by") @db.Uuid
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")

  user       User?     @relation(fields: [userId], references: [id])

  @@index([key])
  @@index([orgId])
  @@index([userId])
  @@map("api_keys")
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  githubId      Int       @unique @map("github_id")
  githubLogin   String    @map("github_login")
  name          String?
  email         String?
  avatarUrl     String?   @map("avatar_url")
  isAdmin       Boolean   @default(false) @map("is_admin")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  apiKeys       ApiKey[]
  repoAccess    UserRepoAccess[]

  @@map("users")
}

model UserRepoAccess {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  orgId       String   @map("org_id")
  repoId      String   @map("repo_id")
  permission  String
  grantedAt   DateTime @default(now()) @map("granted_at")
  grantedBy   String?  @map("granted_by") @db.Uuid

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId, repoId])
  @@index([orgId, repoId])
  @@map("user_repo_access")
}
